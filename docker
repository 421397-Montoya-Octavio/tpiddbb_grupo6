FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src
COPY ["WatchParty.csproj", "."]
RUN dotnet restore "WatchParty.csproj"
COPY . .
RUN dotnet publish "WatchParty.csproj" -c Release -o /app/out

FROM mcr.microsoft.com/dotnet/aspnet:8.0
WORKDIR /app
COPY --from=build /app/out .
ENTRYPOINT ["dotnet", "WatchParty.dll"]